# Libretro Core Makefile for Cytrus

TARGET_NAME := cytrus_ir
EXTERNAL_BASE := libretro/azahar/externals

# Architecture detection
ifeq ($(PLATFORM),ios)
    IS_X64 := 0
else
    UNAME_M := $(shell uname -m)
    ifeq ($(UNAME_M),x86_64)
        IS_X64 := 1
    else ifeq ($(ARCH),x86_64)
        IS_X64 := 1
    else
        IS_X64 := 0
    endif
endif
AR ?= ar
LDFLAGS :=

SOURCES_CXX :=
SOURCES_C   :=

# Core source files
SOURCES_CXX += $(shell find Core/core -name "*.cpp")
# Filter out JIT implementation from core
SOURCES_CXX := $(filter-out Core/core/arm/dynarmic/arm_dynarmic.cpp,$(SOURCES_CXX))
SOURCES_CXX := $(filter-out Core/core/arm/dynarmic/arm_dynarmic_cp15.cpp,$(SOURCES_CXX))

SOURCES_CXX += $(shell find Core/common -name "*.cpp")
SOURCES_CXX += $(shell find Core/video_core -name "*.cpp")
SOURCES_CXX += $(shell find libretro/azahar/src/video_core/renderer_software -name "*.cpp")
SOURCES_CXX := $(filter-out libretro/azahar/src/video_core/renderer_software/renderer_software.cpp,$(SOURCES_CXX))
SOURCES_CXX += libretro/src/video_core/renderer_software/renderer_software.cpp
SOURCES_CXX += $(shell find Core/audio_core -name "*.cpp")
SOURCES_CXX += $(shell find Core/network -name "*.cpp")
SOURCES_CXX += $(shell find Core/input_common -name "*.cpp")
SOURCES_CXX += libretro/src/libretro.cpp
SOURCES_CXX += libretro/src/libretro_emu_window.cpp
SOURCES_CXX += libretro/src/libretro_sink.cpp
SOURCES_CXX += libretro/src/libretro_input.cpp

# Externals
SOURCES_CXX += $(EXTERNAL_BASE)/fmt/src/format.cc
SOURCES_CXX += $(EXTERNAL_BASE)/fmt/src/os.cc
SOURCES_CXX += $(EXTERNAL_BASE)/lodepng/lodepng/lodepng.cpp
SOURCES_C   += $(EXTERNAL_BASE)/inih/inih/ini.c
SOURCES_C   += $(EXTERNAL_BASE)/xxHash/xxhash.c

# libretro-common
SOURCES_C   += libretro/libretro-common/streams/file_stream.c \
               libretro/libretro-common/vfs/vfs_implementation.c \
               libretro/libretro-common/rthreads/rthreads.c \
               libretro/libretro-common/string/stdstring.c \
               libretro/libretro-common/file/file_path.c \
               libretro/libretro-common/file/retro_dirent.c \
               libretro/libretro-common/compat/compat_strl.c \
               libretro/libretro-common/compat/compat_snprintf.c \
               libretro/libretro-common/compat/compat_posix_string.c \
               libretro/libretro-common/compat/fopen_utf8.c \
               libretro/libretro-common/compat/compat_strcasestr.c \
               libretro/libretro-common/compat/compat_strldup.c \
               libretro/libretro-common/encodings/encoding_utf.c \
               libretro/libretro-common/file/file_path_io.c \
               libretro/libretro-common/time/rtime.c

SOURCES_C   += $(shell find $(EXTERNAL_BASE)/zstd/lib/common -name "*.c")
SOURCES_C   += $(shell find $(EXTERNAL_BASE)/zstd/lib/compress -name "*.c")
SOURCES_C   += $(shell find $(EXTERNAL_BASE)/zstd/lib/decompress -name "*.c")
SOURCES_C   += $(EXTERNAL_BASE)/zstd/contrib/seekable_format/zstdseek_compress.c
SOURCES_C   += $(EXTERNAL_BASE)/zstd/contrib/seekable_format/zstdseek_decompress.c
SOURCES_C   += $(shell find $(EXTERNAL_BASE)/enet -name "*.c")
SOURCES_CXX += $(shell find $(EXTERNAL_BASE)/xxHash -name "*.cpp")
SOURCES_CXX += $(shell find $(EXTERNAL_BASE)/soundtouch/source/SoundTouch -name "*.cpp")
SOURCES_CXX += $(shell find $(EXTERNAL_BASE)/teakra/src -name "*.cpp")
# Statically compile boost serialization into the core
SOURCES_CXX += $(shell find $(EXTERNAL_BASE)/boost/libs/serialization/src -name "*.cpp")
SOURCES_CXX += $(shell find $(EXTERNAL_BASE)/boost/libs/url/src -name "*.cpp")
SOURCES_CXX += $(EXTERNAL_BASE)/boost/libs/iostreams/src/file_descriptor.cpp
# MCL externals for dynarmic
SOURCES_CXX += $(EXTERNAL_BASE)/dynarmic/externals/mcl/src/assert.cpp

# Dynarmic (IR and Frontend only, No JIT)
DYNARMIC_DIR := $(EXTERNAL_BASE)/dynarmic/src/dynarmic
SOURCES_CXX_DYNARMIC := $(shell find $(DYNARMIC_DIR)/common -name "*.cpp")
SOURCES_CXX_DYNARMIC += $(shell find $(DYNARMIC_DIR)/frontend/A32 -name "*.cpp")
SOURCES_CXX_DYNARMIC += $(shell find $(DYNARMIC_DIR)/frontend/A64 -name "*.cpp")
SOURCES_CXX_DYNARMIC += $(DYNARMIC_DIR)/frontend/imm.cpp
SOURCES_CXX_DYNARMIC += $(shell find $(DYNARMIC_DIR)/ir -name "*.cpp")

# Filter out platform-specific files and those requiring extra dependencies not needed for IR interpreter
SOURCES_CXX_DYNARMIC := $(filter-out %/spin_lock_arm64.cpp %/spin_lock_x64.cpp,$(SOURCES_CXX_DYNARMIC))
SOURCES_CXX_DYNARMIC := $(filter-out %/x64_disassemble.cpp %/llvm_disassemble.cpp,$(SOURCES_CXX_DYNARMIC))
SOURCES_CXX_DYNARMIC := $(filter-out %/backend/x64/exclusive_monitor.cpp %/backend/arm64/exclusive_monitor.cpp,$(SOURCES_CXX_DYNARMIC))

ifeq ($(IS_X64),1)
    SOURCES_CXX_DYNARMIC += $(DYNARMIC_DIR)/common/spin_lock_x64.cpp
    SOURCES_CXX_DYNARMIC += $(DYNARMIC_DIR)/backend/x64/exclusive_monitor.cpp
    SOURCES_CXX_DYNARMIC += $(DYNARMIC_DIR)/backend/x64/hostloc.cpp
else
    SOURCES_CXX_DYNARMIC += $(DYNARMIC_DIR)/common/spin_lock_arm64.cpp
    SOURCES_CXX_DYNARMIC += $(DYNARMIC_DIR)/backend/arm64/exclusive_monitor.cpp
endif

SOURCES_CXX += $(SOURCES_CXX_DYNARMIC)

# Crypto++ Sources (handled separately as libcryptopp.a)
CRYPTOPP_DIR := $(EXTERNAL_BASE)/cryptopp
CRYPTOPP_SOURCES := $(shell find $(CRYPTOPP_DIR) -name "*.cpp")
CRYPTOPP_SOURCES := $(filter-out %test.cpp %bench.cpp %validat%.cpp %adhoc.cpp %dlltest.cpp %cryptest.cpp %regtest%.cpp,$(CRYPTOPP_SOURCES))
CRYPTOPP_SOURCES := $(filter-out $(CRYPTOPP_DIR)/TestPrograms/% $(CRYPTOPP_DIR)/TestScripts/%,$(CRYPTOPP_SOURCES))

# Remove problematic or excluded files from main lists
SOURCES_CXX := $(filter-out %/main.cpp %/ffmpeg.cpp %/ffmpeg_backend.cpp,$(SOURCES_CXX))
SOURCES_CXX := $(filter-out Core/%_sink.cpp %openal_input.cpp,$(SOURCES_CXX))
SOURCES_CXX := $(filter-out Core/video_core/renderer_vulkan/%,$(SOURCES_CXX))
SOURCES_CXX := $(filter-out Core/video_core/renderer_opengl/%,$(SOURCES_CXX))
SOURCES_CXX += $(shell find Core/web_service -name "*.cpp")
SOURCES_CXX := $(filter-out Core/video_core/shader/shader_jit%,$(SOURCES_CXX))
SOURCES_CXX := $(filter-out Core/video_core/shader/generator/spv_%,$(SOURCES_CXX))
SOURCES_CXX := $(filter-out Core/video_core/shader/generator/glsl_%,$(SOURCES_CXX))
SOURCES_CXX := $(filter-out %/cubeb/% %/dumping/%,$(SOURCES_CXX))
ifeq ($(IS_X64),0)
    SOURCES_CXX := $(filter-out %/mmx_optimized.cpp %/sse_optimized.cpp %/cpu_detect_x86.cpp,$(SOURCES_CXX))
    SOURCES_CXX += libretro/src/soundtouch_stub.cpp
endif
# Always include SoundTouch base files
SOURCES_CXX := $(filter-out Core/audio_core/lle/%,$(SOURCES_CXX))
SOURCES_CXX := $(filter-out Core/network/announce_multiplayer_session.cpp,$(SOURCES_CXX))
SOURCES_CXX := $(filter-out Core/input_common/sdl/%,$(SOURCES_CXX))

# ENet filters (only unix.c for our targets)
SOURCES_C := $(filter-out %/win32.c,$(SOURCES_C))

# Teakra filters
SOURCES_CXX := $(filter-out %/main.cpp %/test%.cpp,$(SOURCES_CXX))

# Include paths
INCFLAGS += -Ilibretro/src -ICore/include -ICore -Ilibretro/libretro-common/include
INCFLAGS += -Ilibretro/azahar/src
INCFLAGS += -I$(EXTERNAL_BASE)/boost
INCFLAGS += -I$(EXTERNAL_BASE)/fmt/include
INCFLAGS += -I$(EXTERNAL_BASE)/dynarmic/src
INCFLAGS += -I$(EXTERNAL_BASE)/dynarmic/externals/mcl/include
INCFLAGS += -I$(EXTERNAL_BASE)
INCFLAGS += -I$(EXTERNAL_BASE)/microprofile
INCFLAGS += -I$(EXTERNAL_BASE)/nihstro/include
INCFLAGS += -I$(EXTERNAL_BASE)/xxHash
INCFLAGS += -I$(EXTERNAL_BASE)/zstd/lib
INCFLAGS += -I$(EXTERNAL_BASE)/zstd/lib/common
INCFLAGS += -I$(EXTERNAL_BASE)/zstd/lib/compress
INCFLAGS += -I$(EXTERNAL_BASE)/zstd/lib/decompress
INCFLAGS += -I$(EXTERNAL_BASE)/zstd/contrib
INCFLAGS += -I$(EXTERNAL_BASE)/json
INCFLAGS += -I$(EXTERNAL_BASE)/lodepng/lodepng
INCFLAGS += -I$(EXTERNAL_BASE)/inih
INCFLAGS += -I$(EXTERNAL_BASE)/enet/include
INCFLAGS += -I$(EXTERNAL_BASE)/dds-ktx
INCFLAGS += -I$(EXTERNAL_BASE)/httplib
INCFLAGS += -I$(EXTERNAL_BASE)/cpp-jwt/include
INCFLAGS += -I$(EXTERNAL_BASE)/zstd/contrib/seekable_format
INCFLAGS += -I$(EXTERNAL_BASE)/soundtouch/include
INCFLAGS += -I$(EXTERNAL_BASE)/teakra/include
INCFLAGS += -I$(EXTERNAL_BASE)/teakra/include/teakra/impl
INCFLAGS += -I$(EXTERNAL_BASE)/dynarmic/externals/oaknut/include
INCFLAGS += -I$(EXTERNAL_BASE)/dynarmic/externals/biscuit/include
INCFLAGS += -I$(EXTERNAL_BASE)/dynarmic/externals/xbyak
INCFLAGS += -I$(EXTERNAL_BASE)/dynarmic/externals/zydis/include
INCFLAGS += -I$(EXTERNAL_BASE)/dynarmic/externals/zydis/dependencies/zycore/include
INCFLAGS += -Ilibretro/externals/openssl/include
INCFLAGS += -ICore/include/network
INCFLAGS += -ICore/include/network/artic_base
# Compiler flags
CXXFLAGS += -fPIC -O3 -ffast-math -fno-strict-aliasing -flto -std=c++20 $(INCFLAGS)
CFLAGS   += -fPIC -O3 -ffast-math -fno-strict-aliasing -flto $(INCFLAGS)

# Libretro defines
CXXFLAGS += -DENABLE_SOFTWARE_RENDERER -D__LIBRETRO__ -DZSTD_DISABLE_ASM -DCPPHTTPLIB_OPENSSL_SUPPORT -DCPP_JWT_USE_VENDORED_NLOHMANN_JSON
CFLAGS   += -DENABLE_SOFTWARE_RENDERER -D__LIBRETRO__ -DZSTD_DISABLE_ASM -DCPPHTTPLIB_OPENSSL_SUPPORT -DCPP_JWT_USE_VENDORED_NLOHMANN_JSON

# Crypto++ defines
CXXFLAGS += -DCRYPTOPP_DISABLE_ASM -DCRYPTOPP_DISABLE_SSSE3 -DCRYPTOPP_DISABLE_AESNI

# OpenSSL configuration
OPENSSL_DIR := libretro/externals/openssl
OPENSSL_LIBS := $(OPENSSL_DIR)/libssl.a $(OPENSSL_DIR)/libcrypto.a

# OS detection
ifeq ($(PLATFORM),ios)
    IPHONEOS_SDK := $(shell xcrun --sdk iphoneos --show-sdk-path)
    CC := $(shell xcrun --sdk iphoneos --find clang)
    CXX := $(shell xcrun --sdk iphoneos --find clang++)
    AR := $(shell xcrun --sdk iphoneos --find ar)
    STRIP := $(shell xcrun --sdk iphoneos --find strip)
    
    # 環境変数 IOS_MIN_VERSION があればそれを使う、なければ 15.0
    MIN_VER := $(IOS_MIN_VERSION)
    ifeq ($(MIN_VER),)
        MIN_VER := 15.0
    endif

    CXXFLAGS += -isysroot $(IPHONEOS_SDK) -miphoneos-version-min=$(MIN_VER) -arch arm64 -fembed-bitcode
    CFLAGS   += -isysroot $(IPHONEOS_SDK) -miphoneos-version-min=$(MIN_VER) -arch arm64 -fembed-bitcode
    LDFLAGS  += -isysroot $(IPHONEOS_SDK) -miphoneos-version-min=$(MIN_VER) -arch arm64 -dynamiclib -fembed-bitcode -framework CoreFoundation -framework Foundation -framework AudioToolbox -framework Security

    TARGET := $(TARGET_NAME)_libretro_ios.dylib
    OPENSSL_CONFIGURE := IPHONEOS_DEPLOYMENT_TARGET=$(MIN_VER) ./Configure ios64-xcrun no-shared no-tests no-unit-test
else
    TARGET := $(TARGET_NAME)_libretro.so
    LDFLAGS += -shared -Wl,--version-script=libretro/notes/link.T
    OPENSSL_CONFIGURE := ./config no-shared no-tests no-unit-test
endif


CXXFLAGS += -include Core/include/common/assert.h -include Core/include/common/logging/log.h

# Filter and deduplicate objects
OBJECTS := $(patsubst %.cpp,%.o,$(filter %.cpp,$(SOURCES_CXX)))
OBJECTS += $(patsubst %.cc,%.o,$(filter %.cc,$(SOURCES_CXX)))
OBJECTS += $(SOURCES_C:.c=.o)
OBJECTS := $(sort $(OBJECTS))

CRYPTOPP_OBJECTS := $(CRYPTOPP_SOURCES:.cpp=.o)

all: $(TARGET)

.PHONY: patch-version
patch-version:
	@echo "Fixing cpp-jwt template and include issues..."
	@mkdir -p libretro/azahar/externals/json/nlohmann 2>/dev/null || true
	@if [ ! -L libretro/azahar/externals/json/nlohmann/json.hpp ]; then ln -sf ../json.hpp libretro/azahar/externals/json/nlohmann/json.hpp 2>/dev/null || true; fi
	@perl -i -pe 's/decltype\(auto\) get_claim_value/T get_claim_value/g' libretro/azahar/externals/cpp-jwt/include/jwt/jwt.hpp 2>/dev/null || true
ifeq ($(PLATFORM),ios)
	@echo "Patching minimum OS version to $(MIN_VER)..."
	@perl -i -pe 's/-(mios|miphoneos|mtvos|mwatchos|mappletvos|mmacosx)-version-min=[0-9.]*/-miphoneos-version-min=$(MIN_VER)/g' libretro/externals/openssl/Configurations/15-ios.conf 2>/dev/null || true
	@for f in $$(grep -rlE "\-(mios|miphoneos|mtvos|mwatchos|mappletvos|mmacosx)-version-min=" libretro/azahar/externals libretro/libretro-super libretro/libretro-common 2>/dev/null); do \
		perl -i -pe 's/-(mios|miphoneos|mtvos|mwatchos|mappletvos|mmacosx)-version-min=[0-9.]*/-miphoneos-version-min=$(MIN_VER)/g' $$f; \
	done || true
	@find . -name "project.pbxproj" -exec perl -i -pe 's/(IPHONEOS|MACOSX|TVOS|WATCHOS)_DEPLOYMENT_TARGET = [0-9.]*;/ $$1_DEPLOYMENT_TARGET = $(MIN_VER);/g' {} + 2>/dev/null || true
	@find . -name "*.xcconfig" -exec perl -i -pe 's/(IPHONEOS|MACOSX|TVOS|WATCHOS)_DEPLOYMENT_TARGET = [0-9.]*/$$1_DEPLOYMENT_TARGET = $(MIN_VER)/g' {} + 2>/dev/null || true
	@find . -name "CMakeLists.txt" -exec perl -i -pe 's/set\(CMAKE_OSX_DEPLOYMENT_TARGET "[0-9.]*"\)/set(CMAKE_OSX_DEPLOYMENT_TARGET "$(MIN_VER)")/g' {} + 2>/dev/null || true
endif

$(OPENSSL_DIR)/configdata.pm: patch-version
	cd $(OPENSSL_DIR) && $(OPENSSL_CONFIGURE)

$(OPENSSL_DIR)/libssl.a: $(OPENSSL_DIR)/configdata.pm
	cd $(OPENSSL_DIR) && make -j$(shell nproc 2>/dev/null || sysctl -n hw.ncpu 2>/dev/null || echo 1) build_libs

$(OPENSSL_DIR)/libcrypto.a: $(OPENSSL_DIR)/libssl.a
	@:

# Ensure OpenSSL is built before anything that might need its headers
$(OBJECTS): $(OPENSSL_LIBS)

$(CRYPTOPP_DIR)/libcryptopp.a: $(CRYPTOPP_OBJECTS)
	$(AR) rcs $@ $(CRYPTOPP_OBJECTS)

$(TARGET): $(OPENSSL_LIBS) $(CRYPTOPP_DIR)/libcryptopp.a $(OBJECTS)
	$(CXX) $(CXXFLAGS) $(OBJECTS) $(CRYPTOPP_DIR)/libcryptopp.a $(OPENSSL_LIBS) -o $@ $(LDFLAGS)

%.o: %.cpp
	$(CXX) $(CXXFLAGS) -c -o $@ $<

%.o: %.cc
	$(CXX) $(CXXFLAGS) -c -o $@ $<

%.o: %.c
	$(CC) $(CFLAGS) -c -o $@ $<

clean:
	rm -f $(OBJECTS) $(TARGET)

print-sources:
	@echo $(SOURCES_CXX)

.PHONY: all clean print-sources
